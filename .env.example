# 环境配置文件
# 请填写您的 API 密钥

# 即梦AI配置（图像生成：文生图、图生图）
JIMENG_AK=
JIMENG_SK=您的即梦SecretKey
JIMENG_MODEL=jimeng-v4

# 豆包大模型配置
# DOUBAO_API_KEY=您的豆包APIKey（两个模型共用同一个 Key）
# DOUBAO_TEXT_MODEL=您的文本模型接入点ID   # 用于提示词增强/Skill路由，纯文本模型即可，例如 Doubao-lite 或 Doubao-pro
# DOUBAO_VISION_MODEL=您的视觉模型接入点ID  # 仅用于作品点评/配色分析，需要多模态视觉能力
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 功能开关
FREE_DAILY_LIMIT=5
IS_TEST_MODE=true

# 微信支付回调地址（可选）
# PAY_NOTIFY_URL=https://yourdomain.com/api/pay/notify
