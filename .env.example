# ===================
# 妙摄 Miaosec - 云函数环境变量
# 在云开发控制台 → 云函数 → 环境变量 中配置（不需要本地 .env）
# 此文件仅作为变量清单参考
# ===================

# === ai 云函数 ===
# 即梦 API（火山引擎，图像生成）
JIMENG_AK=
JIMENG_SK=
JIMENG_MODEL=jimeng-v4

# DeepSeek API（提示词优化、文案）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 微信支付（ai + pay-notify 共用）
WECHAT_APPID=
WECHAT_MCH_ID=
WECHAT_PAY_KEY=

# 业务开关
IS_TEST_MODE=true
FREE_DAILY_LIMIT=5

# === user 云函数 ===
# JWT Secret（自生成 32 位随机串）
# 推荐用：openssl rand -hex 16
JWT_SECRET=
