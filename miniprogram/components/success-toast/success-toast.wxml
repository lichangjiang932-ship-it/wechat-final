<!-- 成功提示组件 - 带动画效果 -->
<view class="toast-overlay {{visible ? 'show' : ''}}">
  <view class="toast-content {{visible ? 'animate-success' : ''}}">
    <view class="toast-icon {{iconType}}">
      <block wx:if="{{iconType === 'check'}}">
        <view class="check-circle">
          <view class="checkmark"></view>
        </view>
      </block>
      <block wx:elif="{{iconType === 'heart'}}">
        <view class="heart-icon animate-heart">❤️</view>
      </block>
      <block wx:elif="{{iconType === 'star'}}">
        <view class="star-icon animate-bounce">⭐</view>
      </block>
      <block wx:else>
        <view class="default-icon">✓</view>
      </block>
    </view>
    <text class="toast-title">{{title}}</text>
    <text class="toast-desc" wx:if="{{desc}}">{{desc}}</text>
  </view>
</view>
