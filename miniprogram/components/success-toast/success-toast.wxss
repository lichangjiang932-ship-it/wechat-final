.toast-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.2s;
}

.toast-overlay.show {
  opacity: 1;
}

.toast-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 64rpx;
  background: rgba(0, 0, 0, 0.75);
  border-radius: 24rpx;
  backdrop-filter: blur(10px);
}

/* 图标 */
.toast-icon {
  margin-bottom: 20rpx;
}

/* 对勾动画 */
.check-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160, #06AD56);
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkmark {
  width: 36rpx;
  height: 20rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(-45deg) translateY(-4rpx);
}

/* 爱心 */
.heart-icon {
  width: 64rpx;
  height: 64rpx;
  background: #FF6FA0;
}

/* 星星 */
.star-icon {
  width: 64rpx;
  height: 64rpx;
  background: #FFB347;
}

/* 默认 · 纯 CSS 打勾 */
.default-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160, #06AD56);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: bold;
}

/* 文字 */
.toast-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.toast-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* SVG mask icons (component-scoped) */
.ic {
  -webkit-mask-repeat: no-repeat; -webkit-mask-position: center; -webkit-mask-size: contain;
  mask-repeat: no-repeat; mask-position: center; mask-size: contain;
}
