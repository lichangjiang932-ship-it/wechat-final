.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 998;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.popup-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.popup-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 999;
  padding: 0 32rpx;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.popup-sheet.show {
  transform: translateY(0);
}

.popup-handle {
  width: 64rpx;
  height: 6rpx;
  background: var(--border-color);
  border-radius: 3rpx;
  margin: 16rpx auto 0;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.popup-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-hint);
}

.popup-content {
  padding: 0 0 24rpx;
  max-height: 60vh;
}

.popup-footer {
  padding: 16rpx 0 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
