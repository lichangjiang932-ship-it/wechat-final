.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(237, 233, 228, 0.6);
}

.nav-inner {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  height: 44px;
  position: relative;
}

.nav-left {
  position: absolute;
  left: 16rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 48rpx;
  font-weight: 300;
}

.nav-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.nav-subtitle {
  font-size: 22rpx;
  margin-top: 2rpx;
}

.nav-right {
  position: absolute;
  right: 16rpx;
  min-width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
