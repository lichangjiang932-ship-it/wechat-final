.pp-mask { position: fixed; inset: 0; z-index: 99999;
  background: rgba(14, 11, 8, 0.78);
  display:flex; align-items:flex-end; justify-content:center; }
.pp-card { width: 100%; max-height: 80vh;
  background: #17120D; border-top-left-radius: 36rpx; border-top-right-radius: 36rpx;
  padding: 48rpx 40rpx 56rpx; box-sizing:border-box;
  display:flex; flex-direction:column; gap: 32rpx; }
.pp-head { display:flex; flex-direction:column; gap: 10rpx;
  padding-bottom: 24rpx; border-bottom: 1rpx solid rgba(253,251,245,0.08); }
.pp-eyebrow { color: #8A7E6E; font-family: "SF Mono","JetBrains Mono",monospace;
  letter-spacing: 0.14em; font-size: 22rpx; }
.pp-title { font-size: 56rpx; line-height: 1.1; color: #FDFBF5;
  font-family: "PingFang SC",serif; }
.pp-title-it { font-style: italic; color: #B0A693; }

.pp-body { max-height: 50vh; padding: 8rpx 0; }
.pp-p { display:block; color: #D4C9B5; font-size: 28rpx;
  line-height: 1.85; margin-bottom: 18rpx; }
.pp-li { display:block; color: #B0A693; font-size: 26rpx;
  line-height: 1.8; padding-left: 12rpx; margin-bottom: 6rpx; }
.pp-link { color: #E8956A; text-decoration: underline; }

.pp-actions { display:flex; gap: 16rpx; padding-top: 16rpx; }
.pp-btn { flex: 1; padding: 28rpx 0; border-radius: 9999rpx;
  font-size: 30rpx; text-align: center; line-height: 1;
  border: none; }
.pp-btn::after { border: none; }
.pp-btn-cream { background: transparent; color: #D4C9B5;
  border: 1rpx solid rgba(253,251,245,0.18); }
.pp-btn-ember { background: #E8956A; color: #FDFBF5; }
