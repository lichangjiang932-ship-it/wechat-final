/* Floating glass dock — editorial ember */
.dock-wrap {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  z-index: 1000;
  display: flex;
  justify-content: center;
  pointer-events: none;
}
.dock {
  pointer-events: auto;
  display: flex;
  align-items: center;
  gap: 6rpx;
  height: 112rpx;
  padding: 0 16rpx;
  margin-bottom: 36rpx;
  border-radius: 9999rpx;
  background: rgba(10,7,4,0.82);
  backdrop-filter: blur(28px) saturate(150%);
  -webkit-backdrop-filter: blur(28px) saturate(150%);
  border: 1rpx solid rgba(241,234,220,0.1);
  box-shadow: 0 24rpx 64rpx -16rpx rgba(0,0,0,0.65), inset 0 1rpx 0 rgba(241,234,220,0.1);
}
.dock-item {
  width: 88rpx; height: 88rpx;
  border-radius: 9999rpx;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.22s cubic-bezier(0.22,1,0.36,1);
}
.dock-item .ic {
  width: 38rpx; height: 38rpx;
  background-color: #8A8072;
  transition: background-color 0.22s ease, transform 0.22s cubic-bezier(0.34,1.56,0.64,1);
}
.dock-item.on .ic { background-color: #FDFBF5; transform: scale(1.08); }
.dock-item:active { transform: scale(0.88); }
.dock-item.center {
  width: 112rpx; height: 112rpx;
  margin: 0 6rpx;
  background: linear-gradient(145deg,#EE7A50 0%,#D45830 100%);
  box-shadow: 0 16rpx 36rpx -10rpx rgba(232,106,60,0.6), 0 4rpx 12rpx rgba(232,106,60,0.35);
  transform: translateY(-10rpx);
  transition: all 0.28s cubic-bezier(0.34,1.56,0.64,1);
}
.dock-item.center:active {
  transform: translateY(-4rpx) scale(0.94);
  box-shadow: 0 10rpx 24rpx -8rpx rgba(232,106,60,0.5), 0 4rpx 10rpx rgba(232,106,60,0.3);
}
.dock-item.center.on { background: linear-gradient(145deg,#EE7A50 0%,#D45830 100%); }
.dock-item.center .ic { width: 42rpx; height: 42rpx; background-color: #FDFBF5 !important; transform: scale(1); }
