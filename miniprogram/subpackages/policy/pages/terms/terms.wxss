/* policy pages — editorial reading */
.policy-page { background: var(--ink-0); min-height: 100vh; color: var(--cream-1); }
.scroll { padding: 80rpx 48rpx 120rpx; }

.hero { padding-bottom: 48rpx; border-bottom: 1rpx solid var(--line); margin-bottom: 48rpx; }
.eyebrow { color: var(--cream-3); display:block; margin-bottom: 16rpx;
  font-family: var(--f-mono); letter-spacing: 0.14em; font-size: 22rpx; }
.title { font-size: 88rpx; line-height: 1; color: var(--cream-0); display:block; margin-bottom: 20rpx; }
.meta { color: var(--cream-3); font-family: var(--f-mono); font-size: 22rpx;
  letter-spacing: 0.06em; }

.content { display:flex; flex-direction:column; }
.h2 { display:block; font-size: 36rpx; color: var(--cream-0);
  font-family: var(--f-display);
  margin: 56rpx 0 24rpx; padding-bottom: 12rpx;
  border-bottom: 1rpx solid var(--line); }
.p { display:block; color: var(--cream-1); font-size: 28rpx;
  line-height: 1.85; margin-bottom: 16rpx; }
.b { color: var(--cream-0); font-weight: 600; }

.foot { margin-top: 96rpx; padding-top: 48rpx;
  border-top: 1rpx solid var(--line);
  display:flex; flex-direction:column; gap: 12rpx; }
.foot-brand { font-size: 56rpx; color: var(--cream-1); }
