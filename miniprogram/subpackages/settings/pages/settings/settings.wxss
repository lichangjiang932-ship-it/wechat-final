/* 设置页面 */
.page {
  background: var(--bg-page);
  min-height: 100vh;
}

/* 内容区域 */
.content {
  padding: 0 24rpx 24rpx;
}

/* 用户信息 */
.user-section {
  padding: 16rpx 0;
}
.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}
.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid var(--border-color);
}
.user-info {
  flex: 1;
}
.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.user-id {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* 设置项 */
.settings-section {
  padding: 16rpx 0;
}
.settings-group {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.group-title {
  display: block;
  padding: 24rpx 24rpx 16rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  font-weight: 500;
}
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}
.setting-item:last-child {
  border-bottom: none;
}
.setting-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.setting-icon {
  font-size: 36rpx;
}
.setting-name {
  font-size: 28rpx;
  color: var(--text-primary);
}
.setting-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.setting-value {
  font-size: 24rpx;
  color: var(--text-hint);
}
.setting-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
}

/* 退出登录 */
.setting-item.logout {
  justify-content: center;
}
.logout-text {
  font-size: 28rpx;
  color: var(--accent);
  font-weight: 500;
}
