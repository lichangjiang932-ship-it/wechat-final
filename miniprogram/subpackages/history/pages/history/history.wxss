/* 我的作品 · Dark editorial */
.page { background: var(--ink-0); min-height: 100vh; }

.label { font-family: var(--f-mono); font-size: 18rpx; letter-spacing: 0.22em; color: var(--cream-3); text-transform: uppercase; }
.body { font-family: var(--f-display); color: var(--cream-0); }
.display { font-family: var(--f-display); color: var(--cream-0); letter-spacing: -0.01em; }
.display-italic { font-style: italic; }

/* Icons */
.ic {
  background: currentColor;
  color: var(--cream-2);
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
  -webkit-mask-size: contain;
  width: 38rpx; height: 38rpx;
}
.ic-back { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='m15 18-6-6 6-6'/></svg>"); }
.ic-grid { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5'><rect x='3' y='3' width='7' height='7'/><rect x='14' y='3' width='7' height='7'/><rect x='3' y='14' width='7' height='7'/><rect x='14' y='14' width='7' height='7'/></svg>"); }

/* Nav */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: var(--ink-0);
  border-bottom: 1rpx solid var(--line);
}
.nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 32rpx; min-height: 44px; }
.nav-back {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  background: rgba(28,28,28,0.6);
  border: 1rpx solid var(--line);
  border-radius: 9999rpx;
}
.nav-back-icon { width: 32rpx; height: 32rpx; background: var(--cream-0); }
.nav-title { font-size: 18rpx; color: var(--cream-2); letter-spacing: 0.22em; }
.nav-count { min-width: 64rpx; text-align: right; font-family: var(--f-mono); font-size: 22rpx; color: var(--cream-3); letter-spacing: 0.06em; }

/* Scroll (padding-top matches nav; inline style sets exact px) */
.scroll { height: 100vh; box-sizing: border-box; }

/* Editorial header — gives breathing room below the nav so first works don't crowd */
.head { padding: 32rpx 28rpx 16rpx; line-height: 0.98; }
.d-big { display: block; font-size: 56rpx; color: var(--cream-0); }

/* Loading */
.loading-row { display: flex; justify-content: center; padding: 120rpx 0; }
.spinner { width: 48rpx; height: 48rpx; border: 4rpx solid var(--line); border-top-color: var(--ember); border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

/* Empty */
.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 48rpx; gap: 18rpx; }
.empty-title { font-size: 36rpx; color: var(--cream-2); margin-top: 4rpx; }
.empty-sub { font-size: 20rpx; color: var(--cream-4); letter-spacing: 0.1em; }
.empty-btn { padding: 20rpx 44rpx; margin-top: 20rpx; font-size: 26rpx; color: #fff; border-radius: 9999rpx; background: var(--ember); }

/* Story list（同首页「他们的镜头 / 今日心事」） */
.story-list { display: flex; flex-direction: column; padding: 0 24rpx; }
.story-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid var(--line);
}
.story-num {
  flex-shrink: 0;
  font-size: 44rpx;
  color: var(--cream-1);
  padding-top: 6rpx;
  min-width: 56rpx;
}
.story-body { flex: 1; display: flex; flex-direction: column; gap: 8rpx; min-width: 0; }
.story-t {
  font-size: 38rpx;
  color: var(--cream-0);
  line-height: 1.12;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.story-meta {
  font-size: 18rpx;
  color: var(--cream-3);
  letter-spacing: 0.12em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.story-thumb {
  width: 152rpx;
  height: 120rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background: var(--ink-2);
  border: 1rpx solid var(--line);
}
.story-actions { display: flex; gap: 10rpx; margin-top: 6rpx; flex-wrap: wrap; }
.story-act {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(0,0,0,0.45);
  border: 1rpx solid var(--line);
  font-family: var(--f-mono);
  font-size: 16rpx;
  color: var(--cream-0);
  letter-spacing: 0.08em;
}
.story-act.danger { color: var(--ember); }

.list-bottom { text-align: center; padding: 48rpx 0 16rpx; font-size: 20rpx; color: var(--cream-4); letter-spacing: 0.1em; }
.safe-bottom { height: 160rpx; }

/* Btn ember (for empty state) */
.btn-ember { box-shadow: 0 12rpx 32rpx -8rpx rgba(232,106,60,0.45); display: inline-flex; align-items: center; justify-content: center; }
.btn-ember:active { opacity: 0.92; transform: scale(0.98); }
