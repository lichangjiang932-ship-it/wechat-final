/* 发现页 - 暖感真实风 */
.page { background: var(--bg-page); min-height: 100vh; }

/* 搜索栏 */
.search-bar {
  display: flex; align-items: center;
  margin: 16rpx 24rpx; padding: 0 24rpx;
  height: 72rpx; background: var(--bg-card);
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-xs);
}
.search-icon { font-size: 28rpx; margin-right: 12rpx; opacity: 0.5; }
.search-placeholder { font-size: 26rpx; color: var(--text-hint); }

/* 分类标签 */
.tab-scroll { margin: 16rpx 0; }
.tab-list { display: inline-flex; align-items: center; padding: 0 24rpx; gap: 12rpx; }
.tab-item {
  padding: 12rpx 28rpx;
  font-size: 26rpx; color: var(--text-secondary);
  border-radius: var(--radius-full); background: var(--bg-card);
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  font-weight: 500; white-space: nowrap;
  box-shadow: var(--shadow-xs);
}
.tab-item.active {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff; font-weight: 600;
  box-shadow: 0 3rpx 12rpx rgba(201, 149, 107, 0.35);
}

/* 瀑布流 */
.waterfall { display: flex; gap: 14rpx; padding: 0 24rpx 40rpx; }
.waterfall-col { flex: 1; display: flex; flex-direction: column; gap: 14rpx; }

/* 作品卡片 */
.waterfall-item {
  background: var(--bg-card); border-radius: var(--radius-lg);
  overflow: hidden; box-shadow: var(--shadow-sm);
  transform: translateZ(0);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.waterfall-item:active { transform: scale(0.97); box-shadow: var(--shadow-xs); }
.waterfall-img { width: 100%; display: block; }
.waterfall-info { padding: 14rpx 16rpx 12rpx; }
.waterfall-title {
  font-size: 26rpx; font-weight: 500; color: var(--text-primary);
  display: block; line-height: 1.4;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.waterfall-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 10rpx; }
.waterfall-likes { font-size: 20rpx; color: var(--text-hint); }
.waterfall-fav {
  font-size: 28rpx; opacity: 0.5;
  transition: opacity 0.2s, transform 0.2s;
}
.waterfall-fav:active { transform: scale(1.2); }
.waterfall-fav.active { opacity: 1; }

/* 做同款按钮 */
.waterfall-action {
  margin: 0 16rpx 16rpx; padding: 12rpx 0;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff; font-size: 24rpx; font-weight: 500;
  text-align: center; border-radius: var(--radius-full);
  box-shadow: 0 2rpx 8rpx rgba(201, 149, 107, 0.3);
}

/* 加载更多 */
.load-more {
  display: flex; align-items: center; justify-content: center;
  gap: 12rpx; padding: 32rpx; font-size: 22rpx; color: var(--text-hint);
}
.spinner-small {
  width: 28rpx; height: 28rpx;
  border: 3rpx solid var(--border-color);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* 搜索弹窗 */
.search-popup {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: var(--bg-page); z-index: 200;
  transform: translateY(-100%); opacity: 0;
  transition: all 0.3s ease;
}
.search-popup.show { transform: translateY(0); opacity: 1; }

.search-popup-header {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 24rpx; padding-top: calc(16rpx + env(safe-area-inset-top));
  background: var(--bg-card);
}
.search-input {
  flex: 1; height: 72rpx; padding: 0 24rpx;
  background: var(--bg-page); border-radius: var(--radius-full);
  font-size: 28rpx; color: var(--text-primary);
}
.search-cancel {
  font-size: 28rpx; color: var(--primary); font-weight: 500;
  padding: 8rpx 16rpx;
}

.search-results { flex: 1; padding: 16rpx 24rpx; }
.search-item {
  display: flex; gap: 16rpx; padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}
.search-item-img {
  width: 120rpx; height: 120rpx;
  border-radius: var(--radius-md); flex-shrink: 0;
}
.search-item-info { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.search-item-title {
  font-size: 28rpx; font-weight: 500; color: var(--text-primary);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.search-item-likes { font-size: 22rpx; color: var(--text-hint); margin-top: 8rpx; }

.search-empty {
  display: flex; align-items: center; justify-content: center;
  padding: 120rpx 60rpx; font-size: 28rpx; color: var(--text-hint);
}
