/* Preview · Image detail dark */
.page { background: var(--ink-0); min-height: 100vh; display: flex; flex-direction: column; }

/* Nav */
.nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--ink-0); border-bottom: 1rpx solid var(--line); }
.nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 24rpx; min-height: 44px; }
.nav-back {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  background: rgba(28,28,28,0.6);
  border: 1rpx solid var(--line);
  border-radius: 9999rpx;
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
}
.nav-back-icon { width: 38rpx; height: 38rpx; background: var(--cream-0); }
.nav-title { font-size: 20rpx; letter-spacing: 0.18em; color: var(--cream-3); }
.nav-actions { display: flex; align-items: center; gap: 8rpx; }
.nav-action { padding: 12rpx; }

/* Image area */
.image-scroll { flex: 1; overflow-y: auto; }
.image-wrap { position: relative; min-height: 400rpx; display: flex; align-items: center; justify-content: center; background: var(--ink-1); }
.preview-img { width: 100%; display: block; }
.image-ph { width: 100%; height: 600rpx; display: flex; align-items: center; justify-content: center; background: var(--ink-1); }
.image-loading { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); }

/* Info section */
.info-section { padding: 32rpx; border-top: 1rpx solid var(--line); }
.info-header { margin-bottom: 20rpx; }
.info-title { font-size: 34rpx; color: var(--cream-0); display: block; margin-bottom: 12rpx; }
.info-meta { display: flex; gap: 16rpx; flex-wrap: wrap; }
.info-meta-item { font-size: 20rpx; color: var(--cream-4); padding: 4rpx 12rpx; background: var(--ink-2); border-radius: 4rpx; }

.info-prompt { background: var(--ink-1); border-radius: 12rpx; padding: 20rpx; display: flex; align-items: flex-start; gap: 16rpx; }
.info-prompt-text { flex: 1; font-size: 26rpx; color: var(--cream-2); line-height: 1.6; }
.info-prompt-copy { font-size: 18rpx; color: var(--ember); flex-shrink: 0; padding: 4rpx 0; }

.safe-bottom { height: 180rpx; }

/* Action bar */
.action-bar { position: fixed; bottom: 0; left: 0; right: 0; z-index: 90; display: flex; align-items: center; justify-content: space-between; padding: 16rpx 32rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); background: var(--ink-0); border-top: 1rpx solid var(--line); }
.action-left { display: flex; align-items: center; gap: 24rpx; }
.action-btn { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 0; }
.action-count { font-size: 20rpx; color: var(--cream-4); }

.action-right { display: flex; align-items: center; }
.btn-primary { background: var(--ember); border-radius: 9999rpx; padding: 16rpx 40rpx; }
.btn-primary-text { font-size: 28rpx; font-weight: 600; color: var(--ink-0); }

/* Popup */
.popup-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 998; opacity: 1; transition: opacity 0.3s; }
.popup-mask.hidden { opacity: 0; pointer-events: none; }
.popup-sheet { position: fixed; bottom: 0; left: 0; right: 0; background: var(--ink-1); border-radius: 24rpx 24rpx 0 0; z-index: 999; padding: 0 32rpx calc(32rpx + env(safe-area-inset-bottom)); transform: translateY(100%); transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1); }
.popup-sheet.show { transform: translateY(0); }
.popup-handle { width: 48rpx; height: 4rpx; background: var(--cream-4); border-radius: 2rpx; margin: 16rpx auto 0; }
.popup-title { display: block; text-align: center; font-size: 28rpx; color: var(--cream-1); padding: 24rpx 0; }

.share-options { display: flex; justify-content: center; gap: 64rpx; padding: 24rpx 0 16rpx; }
.share-btn { display: flex; flex-direction: column; align-items: center; gap: 12rpx; background: transparent; border: none; padding: 0; line-height: normal; }
.share-btn::after { border: none; }
.share-icon-wrap { width: 88rpx; height: 88rpx; background: var(--ink-2); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.share-label { font-size: 20rpx; color: var(--cream-3); }
