/* 会员页面 */
.page {
  background: var(--bg-page);
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 内容 */
.content {
  padding: 0 24rpx;
}

/* 用户信息卡片 */
.member-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: 32rpx;
}
.member-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  width: 100%;
}
.member-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid var(--border-color);
}
.member-info {
  flex: 1;
}
.member-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.member-badge {
  display: inline-block;
  margin-top: 8rpx;
  padding: 4rpx 16rpx;
  background: var(--text-hint);
  color: #fff;
  font-size: 20rpx;
  border-radius: var(--radius-full);
}
.member-badge.year,
.member-badge.month {
  background: linear-gradient(135deg, #C9956B, #B07D55);
}
.member-expire {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 套餐区域 */
.plan-section {
  margin-bottom: 32rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}
.plan-cards {
  display: flex;
  gap: 20rpx;
}
.plan {
  flex: 1;
  position: relative;
  padding: 32rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 4rpx solid transparent;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s;
}
.plan.active {
  border-color: var(--primary);
  background: #FFF8F5;
}
.plan-badge {
  position: absolute;
  top: -12rpx;
  right: 20rpx;
  padding: 4rpx 16rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
}
.plan-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.plan-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.plan-price {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
}
.plan-unit {
  font-size: 24rpx;
  font-weight: 400;
}
.plan-original {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-hint);
  text-decoration: line-through;
}

/* 权益说明 */
.perks-section {
  margin-bottom: 32rpx;
}
.perks-list {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.perk-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}
.perk-item:last-child {
  border-bottom: none;
}
.perk-icon {
  font-size: 36rpx;
}
.perk-text {
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: var(--bg-card);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border-radius: var(--radius-full);
  box-shadow: 0 8rpx 24rpx rgba(201, 149, 107, 0.3);
}
.btn-primary text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}
