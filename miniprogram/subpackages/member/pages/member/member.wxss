/* Member · Editorial subscription */
.page { background: var(--ink-0); min-height: 100vh; }
.scroll { height: 100vh; box-sizing: border-box; padding-bottom: 240rpx; }

.label, .eyebrow {
  font-family: var(--f-mono);
  font-size: 18rpx;
  letter-spacing: 0.22em;
  color: var(--cream-3);
  text-transform: uppercase;
}
.display { font-family: var(--f-display); color: var(--cream-0); letter-spacing: -0.01em; }
.display-italic { font-style: italic; font-family: var(--f-display); }

/* Icons */
.ic {
  background: currentColor;
  color: var(--cream-2);
  width: 38rpx; height: 38rpx;
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
  -webkit-mask-size: contain;
}
.ic-back {
  -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='m15 18-6-6 6-6'/></svg>");
}

/* Header */
.head { padding: 24rpx 48rpx 0; }
.head-row { display: flex; align-items: center; justify-content: space-between; }
.head-eyebrow { color: var(--cream-2); letter-spacing: 0.22em; }
.head-spacer { width: 38rpx; height: 38rpx; }
.head-title { margin-top: 56rpx; line-height: 0.96; }
.d-big { font-size: 84rpx; display: block; color: var(--cream-0); }

/* Status */
.status {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 40rpx 48rpx 0;
  flex-wrap: wrap;
}
.status-dot {
  width: 8rpx; height: 8rpx; border-radius: 50%;
  background: var(--ember);
  box-shadow: 0 0 0 4rpx rgba(232,106,60,0.2);
}
.status-name { color: var(--cream-1); letter-spacing: 0.08em; text-transform: none; }
.status-sep { color: var(--cream-4); }
.status-badge {
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--line);
  color: var(--cream-2);
  letter-spacing: 0.16em;
}
.status-badge.on {
  background: var(--ember);
  border-color: var(--ember);
  color: #fff;
}
.status-expire { color: var(--cream-3); letter-spacing: 0.12em; text-transform: none; margin-left: 6rpx; }

/* Section heading */
.sec { margin-top: 72rpx; padding: 0 48rpx; }
.sec-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.sec-title-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  flex-wrap: wrap;
}
.sec-title, .sec-title-it { font-size: 44rpx; }
.sec-count { font-size: 18rpx; color: var(--cream-3); }

/* Plan cards */
.plan-grid { display: flex; gap: 16rpx; }
.plan-card {
  flex: 1;
  position: relative;
  padding: 28rpx 24rpx 24rpx;
  border-radius: 32rpx;
  background: var(--ink-2);
  border: 1rpx solid var(--line);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  transition: all 0.25s cubic-bezier(0.22,1,0.36,1);
}
.plan-card.on {
  background: linear-gradient(160deg, #2a1810 0%, #1a1008 100%);
  border-color: var(--ember);
  box-shadow: 0 0 0 2rpx var(--ember), 0 20rpx 60rpx -20rpx rgba(232,106,60,0.5);
}
.plan-badge {
  position: absolute;
  top: -14rpx;
  right: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: var(--ember);
  color: #fff;
  font-size: 16rpx;
  font-family: var(--f-mono);
  letter-spacing: 0.16em;
  text-transform: uppercase;
  box-shadow: 0 6rpx 20rpx -6rpx rgba(232,106,60,0.6);
}
.plan-en {
  font-size: 16rpx;
  color: var(--cream-3);
  letter-spacing: 0.22em;
}
.plan-card.on .plan-en { color: var(--ember); }
.plan-n {
  font-size: 32rpx;
  color: var(--cream-0);
  line-height: 1;
}
.plan-price-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-top: 4rpx;
}
.plan-price {
  font-size: 56rpx;
  line-height: 1;
  color: var(--cream-0);
}
.plan-unit {
  font-size: 20rpx;
  color: var(--cream-3);
  font-family: var(--f-mono);
  letter-spacing: 0.06em;
}
.plan-foot {
  font-size: 16rpx;
  color: var(--cream-3);
  letter-spacing: 0.12em;
  margin-top: 8rpx;
  text-transform: none;
}

/* Perks — numbered editorial rows */
.perk-list { display: flex; flex-direction: column; }
.perk-row {
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
  padding: 32rpx 0;
  border-top: 1rpx solid var(--line);
  position: relative;
}
.perk-row:last-child { border-bottom: 1rpx solid var(--line); }
.perk-num {
  flex-shrink: 0;
  font-size: 40rpx;
  color: var(--cream-2);
  line-height: 1;
  padding-top: 4rpx;
  letter-spacing: 0.02em;
}
.perk-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.perk-t { font-size: 34rpx; color: var(--cream-0); line-height: 1.1; }
.perk-meta { font-size: 18rpx; color: var(--cream-3); letter-spacing: 0.14em; text-transform: none; }
.perk-dot {
  width: 6rpx; height: 6rpx;
  border-radius: 50%;
  background: var(--ember);
  margin-top: 22rpx;
  flex-shrink: 0;
  opacity: 0.7;
}

.cta-spacer { height: 260rpx; }

/* Sticky CTA dock */
.cta-dock {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(15,15,15,0) 0%, var(--ink-0) 32%);
  z-index: 500;
}
.cta-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--ink-2);
  border: 1rpx solid var(--line);
  border-radius: 9999rpx;
  padding: 10rpx 10rpx 10rpx 36rpx;
}
.cta-total {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  flex-shrink: 0;
}
.cta-total-l {
  font-size: 14rpx;
  color: var(--cream-3);
  letter-spacing: 0.22em;
}
.cta-total-n-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.cta-total-n {
  font-size: 36rpx;
  line-height: 1;
  color: var(--cream-0);
}
.cta-total-unit {
  font-size: 16rpx;
  color: var(--cream-3);
  font-family: var(--f-mono);
  letter-spacing: 0.08em;
}
.cta-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: var(--ember);
  border-radius: 9999rpx;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(232,106,60,0.5);
}
.cta-btn-t {
  font-family: var(--f-display);
  font-size: 30rpx;
  color: #fff;
  letter-spacing: 0.02em;
}
.cta-btn-arrow {
  color: #fff;
  font-size: 30rpx;
  font-family: var(--f-display);
}
.cta-sub {
  display: block;
  text-align: center;
  margin-top: 14rpx;
  font-size: 14rpx;
  color: var(--cream-4);
  letter-spacing: 0.18em;
}

/* iOS 合规提示 */
.ios-notice {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin: 32rpx 48rpx 0;
  padding: 24rpx 26rpx;
  background: rgba(232, 106, 60, 0.08);
  border: 1rpx solid rgba(232, 106, 60, 0.32);
  border-radius: 20rpx;
}
.ios-notice-dot {
  flex-shrink: 0;
  margin-top: 12rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--ember);
  box-shadow: 0 0 0 6rpx rgba(232, 106, 60, 0.18);
}
.ios-notice-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}
.ios-notice-title {
  font-family: var(--f-display);
  font-size: 28rpx;
  color: var(--cream-0);
  letter-spacing: 0.02em;
}
.ios-notice-sub {
  font-size: 22rpx;
  color: var(--cream-3);
  line-height: 1.55;
  letter-spacing: 0.02em;
}

/* 禁用态 CTA */
.cta-btn-disabled {
  background: rgba(255, 255, 255, 0.08) !important;
  box-shadow: none !important;
  opacity: 0.85;
}
.cta-btn-disabled .cta-btn-t {
  color: var(--cream-3);
}
