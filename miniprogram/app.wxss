/* ============================================================
   Miaosec · Editorial dark-warm design system
   ink / cream / ember · Cormorant + System Sans + JetBrains Mono
   ============================================================ */

page {
  background: var(--ink-0);
  color: var(--cream-1);
  font-family: var(--f-body);
  font-size: 28rpx;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  box-sizing: border-box;

  --ink-0: #0E0B08;
  --ink-1: #17120D;
  --ink-2: #1F1812;
  --ink-3: #2A2118;
  --ink-4: #3A2E22;

  --cream-0: #FDFBF5;
  --cream-1: #F1EADC;
  --cream-2: #C7BBA5;
  --cream-3: #8A8072;
  --cream-4: #5E544A;

  --ember: #E86A3C;
  --ember-soft: rgba(232,106,60,0.15);
  --ember-glow: rgba(232,106,60,0.35);

  --line: rgba(241,234,220,0.08);
  --line-strong: rgba(241,234,220,0.16);
  --glass: rgba(14,11,8,0.82);

  --bg-page: #0E0B08;
  --bg-card: #17120D;
  --bg-card-hover: #1F1812;
  --text-primary: #F1EADC;
  --text-secondary: #8A8072;
  --text-hint: #5E544A;
  --primary: #E86A3C;
  --primary-dark: #C95028;
  --border-color: rgba(241,234,220,0.08);
  --border-color-strong: rgba(241,234,220,0.16);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-full: 9999rpx;
  --shadow-sm: 0 4rpx 12rpx rgba(0,0,0,0.2);
  --shadow-md: 0 8rpx 24rpx rgba(0,0,0,0.3);

  --f-display: "Cormorant Garamond","Source Han Serif SC","Noto Serif SC",Georgia,serif;
  /* 中文场景：吃系统字体反而更准确，避免远程加载 Inter 的体积成本与显示降级 */
  --f-body: "PingFang SC","HarmonyOS Sans SC","Hiragino Sans GB","Microsoft YaHei",system-ui,-apple-system,"Segoe UI","Roboto",sans-serif;
  --f-mono: "JetBrains Mono","SF Mono",ui-monospace,monospace;
}

/* —— Safe-area helpers —— */
.safe-bottom { padding-bottom: env(safe-area-inset-bottom); }
.dock-spacer { height: calc(96rpx + 48rpx + env(safe-area-inset-bottom)); }

/* —— Typography primitives —— */
.display {
  font-family: var(--f-display);
  font-weight: 400;
  letter-spacing: -0.01em;
  line-height: 1.1;
  color: var(--cream-0);
}
.italic, .display-italic {
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 400;
}
.label-mono {
  font-family: var(--f-mono);
  font-size: 20rpx;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--cream-3);
}

/* 閳光偓閳光偓 Divider 閳光偓閳光偓 */
.divider {
  height: 1rpx;
  background: var(--line);
  margin: 0 32rpx;
}

/* 閳光偓閳光偓 Chip 閳光偓閳光偓 */
.chip {
  display: inline-flex;
  align-items: center;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 9999rpx;
  background: var(--ink-3);
  border: 1rpx solid var(--line-strong);
  font-family: var(--f-body);
  font-size: 24rpx;
  color: var(--cream-2);
  white-space: nowrap;
  flex-shrink: 0;
}

/* 閳光偓閳光偓 Tap feedback 閳光偓閳光偓 */
.tap { transition: opacity 0.18s ease; }
.tap:active { opacity: 0.55; }

/* 閳光偓閳光偓 Buttons 閳光偓閳光偓 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: 100%;
  height: 96rpx;
  border-radius: 9999rpx;
  background: linear-gradient(145deg, #EE7A50 0%, #D45830 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.04em;
  box-shadow: 0 16rpx 40rpx -12rpx rgba(232,106,60,0.55);
}
.btn-primary:active { opacity: 0.88; transform: scale(0.98); }

.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 9999rpx;
  border: 1rpx solid var(--line-strong);
  color: var(--cream-2);
  font-size: 28rpx;
}

.btn-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 28rpx;
  border-radius: 9999rpx;
  border: 1rpx solid var(--line-strong);
  color: var(--cream-2);
  font-size: 24rpx;
  white-space: nowrap;
}
.btn-pill-fill {
  background: var(--ember);
  border-color: var(--ember);
  color: #fff;
}

/* 閳光偓閳光偓 Spinner 閳光偓閳光偓 */
.spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255,255,255,0.25);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* 閳光偓閳光偓 Progress bar 閳光偓閳光偓 */
.progress-bar-wrap { margin-top: 16rpx; }
.progress-bar-track {
  height: 4rpx;
  background: var(--line-strong);
  border-radius: 9999rpx;
  overflow: hidden;
}
.progress-bar-fill {
  height: 100%;
  background: var(--ember);
  border-radius: 9999rpx;
  transition: width 0.3s ease;
}

/* 閳光偓閳光偓 Section head 閳光偓閳光偓 */
.sec { margin-top: 48rpx; }
.sec-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}
.sec-count { font-size: 18rpx; color: var(--cream-4); }

/* 閳光偓閳光偓 Popup / sheet 閳光偓閳光偓 */
.popup-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.55);
  z-index: 200;
  transition: opacity 0.28s ease;
}
.popup-mask.hidden { opacity: 0; pointer-events: none; }

.popup-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--ink-1);
  border-top: 1rpx solid var(--line-strong);
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 32rpx 40rpx;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.36s cubic-bezier(0.32,1,0.36,1);
}
.popup-sheet.show { transform: translateY(0); }

.popup-handle {
  width: 64rpx;
  height: 8rpx;
  border-radius: 9999rpx;
  background: var(--line-strong);
  margin: 20rpx auto 32rpx;
}
.popup-eyebrow {
  display: block;
  font-family: var(--f-mono);
  font-size: 18rpx;
  letter-spacing: 0.15em;
  color: var(--ember);
  margin-bottom: 12rpx;
}
.popup-title {
  display: block;
  font-family: var(--f-display);
  font-size: 56rpx;
  color: var(--cream-0);
  margin-bottom: 32rpx;
  line-height: 1.1;
}

/* ================================================================
   SVG Mask Icon System
   ================================================================ */
.ic {
  display: inline-block;
  width: 44rpx;
  height: 44rpx;
  background-color: currentColor;
  -webkit-mask-size: contain;
  mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
  flex-shrink: 0;
}

