/* ================================================================
   Light theme overrides (apply by adding .theme-light to root view)
   ================================================================ */
.theme-light {
  --ink-0: #F6F1EA;
  --ink-1: #EFE8DC;
  --ink-2: #E8DFCF;
  --ink-3: #DDD2BE;
  --ink-4: #CCBFA7;

  --cream-0: #1A1410;
  --cream-1: #2A2018;
  --cream-2: #5E544A;
  --cream-3: #8A8072;
  --cream-4: #B0A697;

  --ember: #D4562A;
  --ember-soft: rgba(212,86,42,0.12);
  --ember-glow: rgba(212,86,42,0.28);

  --line: rgba(30,24,16,0.08);
  --line-strong: rgba(30,24,16,0.18);
  --glass: rgba(246,241,234,0.88);

  --bg-page: #F6F1EA;
  --bg-card: #FFFFFF;
  --bg-card-hover: #EFE8DC;
  --text-primary: #1A1410;
  --text-secondary: #5E544A;
  --text-hint: #8A8072;
  --primary: #D4562A;
  --primary-dark: #B84420;
  --border-color: rgba(30,24,16,0.08);
  --border-color-strong: rgba(30,24,16,0.18);
  --shadow-sm: 0 4rpx 12rpx rgba(0,0,0,0.06);
  --shadow-md: 0 8rpx 24rpx rgba(0,0,0,0.08);

  background: var(--ink-0);
  color: var(--cream-1);
}
.theme-light .display { color: var(--cream-0); }
.theme-light .label-mono, .theme-light .eyebrow { color: var(--cream-3); }
.theme-light .chip { background: var(--ink-1); color: var(--cream-1); }

/* page body paint sync — the page element itself keeps its dark bg,
   but we paint the .page root heavily so user sees cream background */
.theme-light.page,
.page.theme-light { background: var(--ink-0); color: var(--cream-1); min-height: 100vh; }