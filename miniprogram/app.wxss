/* ================================================================
   Eyebrow / HR
   ================================================================ */
.eyebrow {
  font-family: var(--f-mono);
  font-size: 18rpx;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--cream-3);
}
.hr {
  height: 1rpx;
  background: var(--line);
  margin: 28rpx 0 0;
}

/* ================================================================
   Placeholder tone system  (ph + ph-*)
   Radial gradient color fields 閳?used when real images not loaded
   ================================================================ */
.ph {
  position: relative;
  display: block;
  background-size: cover;
  background-position: center;
}
.ph-warm   { background: radial-gradient(at 70% 30%, #C8956B 0%, #7A4A28 100%); }
.ph-cream  { background: radial-gradient(at 60% 40%, #D4C9A8 0%, #9A8C6A 100%); }
.ph-sage   { background: radial-gradient(at 50% 30%, #7A9B72 0%, #3A5232 100%); }
.ph-ink    { background: radial-gradient(at 40% 60%, #3A4C6A 0%, #0E1826 100%); }
.ph-rose   { background: radial-gradient(at 65% 35%, #C87A8A 0%, #6A2A3A 100%); }
.ph-cyber  { background: radial-gradient(at 40% 60%, #4A6AC8 0%, #0E1852 100%); }
.ph-sand   { background: radial-gradient(at 60% 40%, #C8A878 0%, #7A5A2A 100%); }
.ph-fog    { background: radial-gradient(at 50% 40%, #8A9AAA 0%, #3A4A5A 100%); }
.ph-ember  { background: radial-gradient(at 60% 40%, #E86A3C 0%, #6A2A0E 100%); }
.ph-jade   { background: radial-gradient(at 50% 40%, #5AA88A 0%, #1A4A3A 100%); }

/* pulse dot animation for live indicators */
@keyframes pulse-ember {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.4; transform: scale(0.75); }
}

