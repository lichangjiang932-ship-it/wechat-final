/* ============================================
   简约质感风 · 轻颜/妙鸭调性
   克制配色 + 暖色纯色 + 纸张纹理
   支持深色模式
   ============================================ */

page {
  background-color: #F8F6F3;
  font-family: 'PingFang SC', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #3A3530;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  
  /* ===== 配色：奶茶/暖杏/米色系 ===== */
  --primary: #C9956B;
  --primary-dark: #B07D55;
  --primary-light: #FBF5EB;
  --accent: #D4876E;
  --accent-warm: #C9A07A;
  
  --text-primary: #3A3530;
  --text-secondary: #7A7268;
  --text-hint: #B0A89E;
  --text-price: #C06050;
  
  --bg-page: #F8F6F3;
  --bg-card: #FFFFFF;
  --bg-warm: #FBF8F4;
  --bg-mask: rgba(0, 0, 0, 0.35);
  --border-color: #EDE9E4;
  
  /* 圆角规范 */
  --radius-xl: 24rpx;
  --radius-lg: 16rpx;
  --radius-md: 12rpx;
  --radius-sm: 8rpx;
  --radius-xs: 4rpx;
  --radius-full: 9999rpx;
  
  /* 阴影：极柔 */
  --shadow-xs: 0 1rpx 2rpx rgba(60, 50, 40, 0.03);
  --shadow-sm: 0 2rpx 8rpx rgba(60, 50, 40, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(60, 50, 40, 0.05);
  --shadow-lg: 0 8rpx 32rpx rgba(60, 50, 40, 0.06);
  --shadow-float: 0 8rpx 24rpx rgba(60, 50, 40, 0.08);
}

/* ===== 深色模式 ===== */
@media (prefers-color-scheme: dark) {
  page {
    background-color: #1A1816;
    color: #E8E4DE;
    
    --text-primary: #E8E4DE;
    --text-secondary: #A09890;
    --text-hint: #6A625A;
    --text-price: #E08070;
    
    --bg-page: #1A1816;
    --bg-card: #2A2622;
    --bg-warm: #2E2A26;
    --bg-mask: rgba(0, 0, 0, 0.6);
    --border-color: #3A3632;
    
    --primary-light: #3A3228;
    
    --shadow-xs: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
    --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.25);
    --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
    --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.35);
    --shadow-float: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
  }
}

/* ===== 全局reset ===== */
view, text, image, navigator, button, input, textarea, label {
  box-sizing: border-box;
}

button { background: none; padding: 0; margin: 0; line-height: inherit; font-size: inherit; color: inherit; }
button::after { border: none; }

/* ===== 按压反馈 ===== */
.tap-light { transition: opacity 0.15s; }
.tap-light:active { opacity: 0.7; }

.tap-scale { transition: transform 0.18s ease; }
.tap-scale:active { transform: scale(0.97); }

.tap-bg { transition: background 0.15s; }
.tap-bg:active { background: rgba(0, 0, 0, 0.04); }

/* ===== 通用卡片 ===== */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

/* ===== 通用标题栏 ===== */
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.section-more {
  font-size: 24rpx;
  color: var(--text-hint);
}
.section-more::after {
  content: '›';
  margin-left: 2rpx;
}

/* ===== 通用按钮 ===== */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: var(--primary);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 16rpx rgba(201, 149, 107, 0.25);
  transition: all 0.2s;
}
.btn-primary:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

/* ===== 标签 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-xs);
  font-size: 20rpx;
  font-weight: 500;
  color: #fff;
}
.tag-hot { background: #C9956B; }
.tag-new { background: var(--accent); }
.tag-rec { background: #9AAF8C; }

/* ===== 骨架屏 ===== */
.skeleton {
  background: linear-gradient(90deg, var(--bg-page) 25%, var(--border-color) 50%, var(--bg-page) 75%);
  background-size: 400% 100%;
  animation: skeleton-shimmer 1.5s ease infinite;
  border-radius: var(--radius-md);
}
@keyframes skeleton-shimmer {
  0% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* ===== 加载动画 ===== */
@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.rotate { animation: rotate 1s linear infinite; }

/* ===== 入场动画 ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.94); }
  to   { opacity: 1; transform: scale(1); }
}
.animate-fade-up   { animation: fadeInUp 0.4s cubic-bezier(0.22, 1, 0.36, 1) both; }
.animate-fade-in   { animation: fadeIn   0.35s ease both; }
.animate-scale-in  { animation: scaleIn  0.3s cubic-bezier(0.22, 1, 0.36, 1) both; }
.delay-1 { animation-delay: 0.06s; }
.delay-2 { animation-delay: 0.12s; }
.delay-3 { animation-delay: 0.18s; }
.delay-4 { animation-delay: 0.24s; }

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 60rpx;
  color: var(--text-hint);
}
.empty-state .empty-icon { font-size: 120rpx; margin-bottom: 24rpx; opacity: 0.4; }
.empty-state .empty-text { font-size: 26rpx; text-align: center; line-height: 1.6; }

/* ===== 安全区域 ===== */
.safe-bottom { padding-bottom: env(safe-area-inset-bottom); }

/* ===== 遮罩 ===== */
.mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: var(--bg-mask);
  z-index: 998;
}

/* ===== tabBar 毛玻璃 ===== */
page { --tab-bar-height: 100rpx; }
.weui-tabbar {
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  background: rgba(255, 255, 255, 0.95) !important;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  padding-bottom: env(safe-area-inset-bottom);
}

@media (prefers-color-scheme: dark) {
  .weui-tabbar {
    background: rgba(26, 24, 22, 0.95) !important;
    border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  }
}