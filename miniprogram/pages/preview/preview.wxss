/* 图片详情页 */
.page {
  background: #000;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 导航栏 */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.8);
  backdrop-filter: blur(10px);
  z-index: 100;
}
.nav-inner {
  display: flex;
  align-items: center;
  height: 44px;
  padding: 0 24rpx;
}
.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}
.back-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
}
.nav-favorite {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.favorite-icon {
  font-size: 36rpx;
}

/* 图片区域 */
.image-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0 200rpx;
  position: relative;
}
.preview-image {
  max-width: 100%;
}
.image-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}
.loading-text {
  color: #fff;
  font-size: 28rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(10px);
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.action-info {
  margin-bottom: 20rpx;
}
.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.action-likes {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 操作按钮组 */
.action-btns {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 50rpx;
  border: 2rpx solid #eee;
}

.action-btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #C9956B 0%, #B07D55 100%);
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(201, 149, 107, 0.3);
}

.action-btn-secondary {
  background: #f8f8f8;
  border-color: #eee;
}

.action-btn-secondary.active {
  background: #FFF5F5;
  border-color: #FFB6C1;
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
}

.action-btn-primary .btn-icon,
.action-btn-primary .btn-text {
  color: #fff;
  font-weight: 600;
}

.action-btn-secondary.active .btn-text {
  color: #E91E63;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* ========== 弹窗 ========== */
.popup-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 998;
  opacity: 1; transition: opacity 0.3s;
}
.popup-mask.hidden { opacity: 0; pointer-events: none; }
.popup-sheet {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; border-radius: 32rpx 32rpx 0 0;
  z-index: 999; padding: 0 32rpx calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%); transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}
.popup-sheet.show { transform: translateY(0); }
.popup-handle { width: 64rpx; height: 6rpx; background: #E0E0E0; border-radius: 3rpx; margin: 16rpx auto 0; }
.popup-title { display: block; text-align: center; font-size: 30rpx; font-weight: 600; padding: 24rpx 0; color: #333; }

/* 分享选项 */
.share-options { display: flex; justify-content: center; gap: 48rpx; padding: 32rpx 0; }
.share-btn {
  display: flex; flex-direction: column; align-items: center; gap: 12rpx;
  background: transparent; border: none; padding: 0;
}
.share-btn::after { border: none; }
.share-icon {
  width: 96rpx; height: 96rpx;
  background: #F8F6F3; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx;
}
.share-name { font-size: 24rpx; color: #666; }
