<!-- 图片详情页 -->
<view class="page">
  <!-- 导航栏 -->
  <view class="nav" style="height: {{navBarHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-back" bindtap="goBack">
        <text class="back-icon">‹</text>
      </view>
      <text class="nav-title">作品详情</text>
      <view class="nav-favorite" bindtap="onFavorite">
        <text class="favorite-icon">{{isFavorite ? '❤️' : '🤍'}}</text>
      </view>
    </view>
  </view>

  <!-- 图片区域 -->
  <view class="image-container">
    <image 
      class="preview-image" 
      src="{{imageUrl}}" 
      mode="widthFix"
      bindtap="onImageTap"
      bindload="onImageLoad"
    />
    <view class="image-loading" wx:if="{{!imageLoaded}}">
      <text class="loading-text">图片加载中...</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar safe-bottom">
    <view class="action-info">
      <text class="action-title">{{title || '作品'}}</text>
      <text class="action-likes" wx:if="{{likes}}">{{likes}} 赞</text>
    </view>
    <view class="action-btns">
      <view class="action-btn action-btn-secondary" bindtap="onFavorite">
        <text class="btn-icon">{{isFavorite ? '❤️' : '🤍'}}</text>
        <text class="btn-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
      </view>
      <view class="action-btn action-btn-secondary" bindtap="onSaveToAlbum">
        <text class="btn-icon">💾</text>
        <text class="btn-text">保存</text>
      </view>
      <view class="action-btn action-btn-secondary" bindtap="onShareTap">
        <text class="btn-icon">🔗</text>
        <text class="btn-text">分享</text>
      </view>
      <view class="action-btn action-btn-primary" bindtap="onMakeSame">
        <text class="btn-icon">✨</text>
        <text class="btn-text">做同款</text>
      </view>
    </view>
  </view>

  <!-- 分享菜单弹窗 -->
  <view class="popup-mask {{showShareMenu ? '' : 'hidden'}}" bindtap="closeShareMenu"></view>
  <view class="popup-sheet {{showShareMenu ? 'show' : ''}}">
    <view class="popup-handle"></view>
    <text class="popup-title">分享作品</text>
    <view class="share-options">
      <button class="share-btn" open-type="share" bindtap="closeShareMenu">
        <view class="share-icon">💬</view>
        <text class="share-name">发给好友</text>
      </button>
      <view class="share-btn" bindtap="onSaveToAlbum">
        <view class="share-icon">🖼️</view>
        <text class="share-name">保存图片</text>
      </view>
    </view>
  </view>
</view>