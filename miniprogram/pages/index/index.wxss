/* Home · Editorial gallery */
.page { background: var(--ink-0); min-height: 100vh; }
.scroll { height: 100vh; box-sizing: border-box; }

/* Eyebrow / label */
.eyebrow { font-size: 18rpx; letter-spacing: 0.22em; color: var(--cream-3); font-family: var(--f-mono); text-transform: uppercase; }
.label { font-size: 18rpx; letter-spacing: 0.18em; color: var(--cream-3); font-family: var(--f-mono); text-transform: uppercase; }
.display { font-family: var(--f-display); color: var(--cream-0); letter-spacing: -0.01em; }
.display-italic { font-style: italic; font-family: var(--f-display); }

/* Masthead */
.masthead { padding: 36rpx 56rpx 0; }
.mast-top { display: flex; align-items: center; justify-content: space-between; }
.mast-icons { display: flex; gap: 24rpx; }
.mast-title { margin-top: 28rpx; line-height: 0.98; }
.d-big { font-size: 92rpx; display: block; }
.mast-sub { display: block; margin-top: 22rpx; font-size: 24rpx; color: var(--cream-3); line-height: 1.55; max-width: 520rpx; }

/* Icons (small inline) */
.ic { width: 40rpx; height: 40rpx; background: currentColor; color: var(--cream-2); -webkit-mask-repeat: no-repeat; -webkit-mask-position: center; -webkit-mask-size: contain; }
.ic-search { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><circle cx='11' cy='11' r='7'/><path d='m20 20-3.5-3.5'/></svg>"); }
.ic-bell { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9'/><path d='M10.3 21a1.94 1.94 0 0 0 3.4 0'/></svg>"); }
.ic-play { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='black'><path d='M8 5v14l11-7z'/></svg>"); }
.ic-portrait { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='8' r='4'/><path d='M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8'/></svg>"); }
.ic-id { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='5' width='18' height='14' rx='2'/><circle cx='9' cy='11' r='2.5'/><path d='M5 17c0-1.8 1.8-3 4-3s4 1.2 4 3'/><path d='M15 10h4M15 13h3'/></svg>"); }
.ic-brush { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M9 11L17.5 2.5a2 2 0 0 1 3 3L12 14'/><path d='M9 11l-4 4a3 3 0 1 0 4 4l4-4'/></svg>"); }
.ic-time { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='9'/><path d='M12 7v5l3 2'/></svg>"); }
.ic-wand { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M15 4V2M15 10V8M18 7h2M10 7h2M16.5 5.5l1.4-1.4M13.6 5.5 12.2 4.1M3 21l10-10M15 9l-3 3'/></svg>"); }
.ic-orbit { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='3'/><ellipse cx='12' cy='12' rx='10' ry='4' transform='rotate(45 12 12)'/></svg>"); }

/* Hero */
.hero { position: relative; margin: 40rpx 48rpx 0; height: 560rpx; border-radius: 40rpx; overflow: hidden; }
.hero-ph { position: absolute; inset: 0; }
.hero-img { position: absolute; inset: 0; width: 100%; height: 100%; }
.hero-scrim { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(15,15,15,0) 45%, rgba(15,15,15,0.78) 100%); z-index: 1; pointer-events: none; }
.hero-top { position: absolute; top: 32rpx; left: 32rpx; display: flex; align-items: center; gap: 14rpx; z-index: 2; }
.live-dot { position: relative; width: 14rpx; height: 14rpx; }
.live-pulse { position: absolute; inset: 0; border-radius: 50%; background: var(--cream-0); animation: pulse-ember 2s infinite; }
.hero-live { color: var(--cream-0) !important; font-size: 18rpx; }
.hero-play { position: absolute; top: 28rpx; right: 28rpx; width: 80rpx; height: 80rpx; border-radius: 50%; background: rgba(253,251,245,0.18); backdrop-filter: blur(12rpx); display: flex; align-items: center; justify-content: center; z-index: 2; }
.hero-play .ic { width: 28rpx; height: 28rpx; color: var(--cream-0); }
.hero-bottom { position: absolute; left: 40rpx; right: 40rpx; bottom: 40rpx; z-index: 2; }
.hero-title { display: block; font-size: 72rpx; line-height: 1; color: var(--cream-0); }
.hero-desc { display: block; margin-top: 12rpx; font-size: 24rpx; color: rgba(253,251,245,0.85); }

/* Section */
.sec { margin-top: 56rpx; padding: 0 48rpx; }
.sec-last { padding-bottom: 40rpx; }
.sec-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 28rpx; }
.sec-title { font-size: 44rpx; }
.sec-title-it { font-size: 44rpx; }
.sec-count { font-size: 18rpx; }
.sec-sub-eyebrow { display: block; font-size: 18rpx; margin-bottom: 12rpx; }
.sec-title-row { display: flex; align-items: baseline; gap: 12rpx; flex-wrap: wrap; }

/* Studio grid */
.studio-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; }
.studio-cell { position: relative; height: 192rpx; border-radius: 36rpx; overflow: hidden; background: var(--ink-2); border: 1rpx solid var(--line); }
.studio-orb { position: absolute; right: -40rpx; top: -40rpx; width: 220rpx; height: 220rpx; border-radius: 50%; opacity: 0.85; }
.studio-body { position: relative; padding: 28rpx; height: 100%; display: flex; flex-direction: column; justify-content: space-between; box-sizing: border-box; }
.studio-body .ic { width: 36rpx; height: 36rpx; color: var(--cream-0); }
.studio-text { display: flex; flex-direction: column; gap: 4rpx; }
.studio-n { font-size: 34rpx; color: var(--cream-0); }
.studio-en { font-size: 16rpx; color: var(--cream-3); }

/* Stories */
.story-list { display: flex; flex-direction: column; }
.story-row { display: flex; align-items: flex-start; gap: 28rpx; padding: 28rpx 0; border-top: 1rpx solid var(--line); }
.story-num { flex-shrink: 0; font-size: 44rpx; color: var(--cream-1); padding-top: 6rpx; }
.story-body { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.story-t { font-size: 38rpx; color: var(--cream-0); }
.story-meta { font-size: 18rpx; color: var(--cream-3); }
.story-thumb { width: 152rpx; height: 120rpx; border-radius: 20rpx; flex-shrink: 0; }

/* ========== 热门模板 ========== */
.tpl-scroll {
  display: flex;
  gap: 24rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
  /* 隐藏滚动条 */
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.tpl-scroll::-webkit-scrollbar { display: none; }

.tpl-card {
  flex-shrink: 0;
  width: 260rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: var(--ink-2);
  border: 1rpx solid var(--line);
}

.tpl-cover {
  position: relative;
  height: 300rpx;
  overflow: hidden;
}
.tpl-img { width: 100%; height: 100%; display: block; }
.tpl-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: rgba(253,251,245,0.16);
  border: 1rpx solid rgba(253,251,245,0.24);
  font-size: 16rpx;
  color: #fff;
  font-family: var(--f-mono);
  letter-spacing: 0.1em;
}

.tpl-info {
  padding: 16rpx 20rpx 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.tpl-name { font-size: 28rpx; color: var(--cream-0); font-family: var(--f-display); }
.tpl-uses { font-size: 18rpx; color: var(--cream-3); font-family: var(--f-mono); }

/* ========== Bento gallery (Inspire) ========== */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: 200rpx 200rpx 240rpx;
  gap: 14rpx;
}
.bento-cell {
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
  background: var(--ink-2);
  border: 1rpx solid var(--line);
}
.bento-img { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
.bento-shade {
  position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(15,15,15,0) 42%, rgba(15,15,15,0.82) 100%);
  pointer-events: none;
}
.bento-tag {
  position: absolute;
  top: 14rpx; left: 16rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: rgba(253,251,245,0.12);
  backdrop-filter: blur(10rpx);
  font-size: 16rpx;
  color: var(--cream-0);
  font-family: var(--f-mono);
  letter-spacing: 0.16em;
  text-transform: uppercase;
}
.bento-body {
  position: absolute;
  left: 20rpx; right: 20rpx; bottom: 56rpx;
  display: flex; flex-direction: column; gap: 4rpx;
  z-index: 2;
}
.bento-name {
  font-size: 30rpx;
  color: var(--cream-0);
  line-height: 1.1;
}
.bento-meta {
  font-size: 16rpx;
  color: rgba(253,251,245,0.75);
  font-family: var(--f-mono);
  letter-spacing: 0.1em;
}

/* ========== Community bento mosaic ========== */
.comm-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: 180rpx 180rpx 180rpx;
  gap: 12rpx;
  margin-top: 28rpx;
}
.comm-cell {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  background: var(--ink-2);
  border: 1rpx solid var(--line);
}
.comm-img { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
.comm-shade {
  position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(15,15,15,0) 55%, rgba(15,15,15,0.78) 100%);
  pointer-events: none;
}
.comm-by {
  position: absolute;
  top: 14rpx; left: 16rpx;
  font-size: 18rpx;
  color: var(--cream-0);
  font-family: var(--f-mono);
  letter-spacing: 0.08em;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.6);
  z-index: 2;
}

/* ========== 动画 ========== */
@keyframes pulse-ember {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.6); opacity: 0.5; }
}


/* AI 生成显著标识（合规要求：深度合成-AI绘画类目） */
.ai-banner-inline {
  display: flex; align-items: center; gap: 12rpx;
  margin: 24rpx 28rpx 0;
  padding: 14rpx 18rpx;
  background: rgba(232, 106, 60, 0.10);
  border: 1rpx solid rgba(232, 106, 60, 0.28);
  border-radius: 16rpx;
}
.ai-banner-badge {
  font-family: var(--f-mono);
  font-size: 18rpx; font-weight: 700;
  color: #fff; background: var(--ember);
  padding: 4rpx 10rpx; border-radius: 6rpx;
  letter-spacing: 0.06em;
}
.ai-banner-t { font-size: 22rpx; color: var(--cream-1); letter-spacing: 0.02em; flex: 1; }

.ai-corner {
  position: absolute;
  top: 12rpx; right: 12rpx;
  z-index: 3;
  font-family: var(--f-mono);
  font-size: 18rpx; font-weight: 700;
  color: #fff; background: rgba(0, 0, 0, 0.55);
  padding: 4rpx 10rpx; border-radius: 6rpx;
  letter-spacing: 0.06em;
}
.ai-corner-hero { top: auto; bottom: 24rpx; left: 24rpx; right: auto; padding: 6rpx 14rpx; font-size: 20rpx; }
.ai-corner-bento { top: 16rpx; right: 16rpx; }
.tpl-cover, .bento-cell, .comm-cell, .hero { position: relative; }

