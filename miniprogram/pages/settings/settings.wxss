/* 设置页面 */
.page {
  background: var(--bg-page);
  min-height: 100vh;
}

/* 导航栏 */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  z-index: 100;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.nav-inner {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
}
.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon {
  font-size: 48rpx;
  color: var(--text-primary);
  font-weight: 300;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 60rpx;
}

/* 用户信息 */
.user-section {
  padding: calc(var(--nav-height, 88rpx) + 24rpx) 24rpx 24rpx;
}
.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}
.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid var(--border-color);
}
.user-info {
  flex: 1;
}
.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.user-id {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* 设置项 */
.settings-section {
  padding: 0 24rpx 24rpx;
}
.settings-group {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.group-title {
  display: block;
  padding: 24rpx 24rpx 16rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  font-weight: 500;
}
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}
.setting-item:last-child {
  border-bottom: none;
}
.setting-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.setting-icon {
  font-size: 36rpx;
}
.setting-name {
  font-size: 28rpx;
  color: var(--text-primary);
}
.setting-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.cache-size {
  font-size: 24rpx;
  color: var(--text-hint);
}
.setting-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
}

/* picker 选择器 */
.setting-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.picker-value {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 退出登录 */
.logout-section {
  padding: 32rpx 24rpx;
}
.logout-btn {
  text-align: center;
  padding: 28rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  color: #FF6B6B;
  box-shadow: var(--shadow-sm);
}

/* 版本信息 */
.version-info {
  padding: 48rpx 24rpx;
  text-align: center;
}
.version-text {
  font-size: 22rpx;
  color: var(--text-hint);
}