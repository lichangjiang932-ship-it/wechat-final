<!-- 我的收藏页面 -->
<view class="page">
  <!-- 导航栏 -->
  <view class="nav" style="height: {{navBarHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-back" bindtap="goBack">
        <text class="back-icon">‹</text>
      </view>
      <text class="nav-title">我的收藏</text>
      <text class="nav-count" wx:if="{{favorites.length > 0}}">{{favorites.length}}</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <scroll-view
    scroll-y
    class="content"
    style="padding-top: calc({{navBarHeight}}px + 16rpx);"
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{loading && favorites.length === 0}}">
      <view class="spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:elif="{{empty}}">
      <text class="empty-icon">❤️</text>
      <text class="empty-title">暂无收藏</text>
      <text class="empty-desc">去发现页寻找喜欢的作品吧</text>
      <view class="empty-btn" bindtap="goDiscover">去发现</view>
    </view>

    <!-- 收藏列表 -->
    <block wx:else>
      <view class="favorites-grid">
        <view class="fav-item" wx:for="{{favorites}}" wx:key="id">
          <image class="fav-image" src="{{item.url}}" mode="aspectFill" lazy-load bindtap="onPreview" data-index="{{index}}"/>
          <view class="fav-info">
            <text class="fav-title">{{item.title || '作品'}}</text>
          </view>
          <view class="fav-actions">
            <view class="action-btn primary" bindtap="onMakeSame" data-item="{{item}}">做同款</view>
            <view class="action-btn" bindtap="onRemove" data-id="{{item.id}}">取消</view>
          </view>
        </view>
      </view>
      <view class="list-bottom">~ 共 {{favorites.length}} 个收藏 ~</view>
    </block>
  </scroll-view>
</view>