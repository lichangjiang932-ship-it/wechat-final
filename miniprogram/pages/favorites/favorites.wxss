/* Favorites · Dark editorial */
.page { background: var(--ink-0); min-height: 100vh; }

.nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--ink-0); border-bottom: 1rpx solid var(--line); }
.nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 32rpx; min-height: 44px; }
.nav-title { font-size: 20rpx; letter-spacing: 0.16em; color: var(--cream-2); }

.content { height: 100vh; box-sizing: border-box; }

/* Editorial header — gives breathing room below the nav so first works don't crowd */
.head { padding: 32rpx 20rpx 16rpx; line-height: 0.98; }
.d-big { display: block; font-size: 56rpx; color: var(--cream-0); }

/* Empty */
.empty { display: flex; flex-direction: column; align-items: center; gap: 20rpx; padding: 120rpx 32rpx; }
.empty-title { font-size: 40rpx; color: var(--cream-2); margin-top: 8rpx; }
.empty-sub { font-size: 20rpx; letter-spacing: 0.1em; color: var(--cream-4); }

.waterfall {
  display: flex;
  gap: 16rpx;
  padding: 4rpx 24rpx 0;
}

.water-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.work-card {
  border-radius: 24rpx;
  overflow: hidden;
  background: var(--ink-1);
  border: 1rpx solid var(--line);
}

.work-cover {
  position: relative;
  width: 100%;
}

.work-cover.ratio-tall { padding-top: 138%; }
.work-cover.ratio-mid { padding-top: 118%; }
.work-cover.ratio-wide { padding-top: 92%; }

.work-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.work-body {
  padding: 18rpx;
}

.work-topic {
  display: block;
  font-size: 22rpx;
  color: var(--cream-1);
  line-height: 1.45;
  min-height: 64rpx;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.work-author {
  display: block;
  font-size: 20rpx;
  color: var(--cream-3);
  line-height: 1.3;
}

@media (max-width: 375px) {
  .waterfall { gap: 12rpx; padding: 4rpx 18rpx 0; }
  .water-col { gap: 12rpx; }
  .work-body { padding: 14rpx; }
}

/* Loading */
.loading-row { display: flex; justify-content: center; padding: 32rpx; }


/* AI 生成显著标识（合规要求：深度合成-AI绘画类目） */
.ai-banner-inline {
  display: flex; align-items: center; gap: 12rpx;
  margin: 24rpx 28rpx 16rpx;
  padding: 14rpx 18rpx;
  background: rgba(232, 106, 60, 0.10);
  border: 1rpx solid rgba(232, 106, 60, 0.28);
  border-radius: 16rpx;
}
.ai-banner-badge {
  font-family: var(--f-mono);
  font-size: 18rpx; font-weight: 700;
  color: #fff; background: var(--ember);
  padding: 4rpx 10rpx; border-radius: 6rpx;
  letter-spacing: 0.06em;
}
.ai-banner-t { font-size: 22rpx; color: var(--cream-1); flex: 1; }

.ai-corner {
  position: absolute;
  top: 12rpx; right: 12rpx;
  z-index: 3;
  font-family: var(--f-mono);
  font-size: 18rpx; font-weight: 700;
  color: #fff; background: rgba(0, 0, 0, 0.55);
  padding: 4rpx 10rpx; border-radius: 6rpx;
  letter-spacing: 0.06em;
}
.work-cover { position: relative; }

