.page {
  background: var(--ink-0);
  min-height: 100vh;
}

.display { font-family: var(--f-display); color: var(--cream-0); }
.display-italic { font-style: italic; font-family: var(--f-display); }
.eyebrow {
  font-size: 18rpx;
  letter-spacing: 0.18em;
  color: var(--cream-3);
  font-family: var(--f-mono);
  text-transform: uppercase;
}

.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(14, 11, 8, 0.88);
  backdrop-filter: blur(18rpx) saturate(140%);
  -webkit-backdrop-filter: blur(18rpx) saturate(140%);
  border-bottom: 1rpx solid var(--line);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  min-height: 44px;
}

.nav-title {
  display: block;
  font-size: 34rpx;
  color: var(--cream-0);
  font-family: var(--f-display);
}

.nav-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--cream-3);
}

.search-btn {
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 9999rpx;
  border: 1rpx solid var(--line-strong);
  background: var(--ink-2);
  display: flex;
  align-items: center;
  color: var(--cream-2);
  font-size: 24rpx;
}

.search-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 99;
  background: rgba(14, 11, 8, 0.94);
  border-bottom: 1rpx solid var(--line);
  padding: 12rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  transform: translateY(-100%);
  opacity: 0;
  transition: all 0.22s ease;
  pointer-events: none;
}

.search-bar.show {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.search-input {
  flex: 1;
  height: 72rpx;
  border-radius: 9999rpx;
  padding: 0 24rpx;
  background: var(--ink-2);
  border: 1rpx solid var(--line-strong);
  color: var(--cream-1);
  font-size: 26rpx;
}

.search-cancel {
  font-size: 24rpx;
  color: var(--cream-3);
}

.tabs {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 98;
  background: rgba(14, 11, 8, 0.92);
  border-bottom: 1rpx solid var(--line);
}

.tab-list {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 20rpx;
  height: 80rpx;
  width: max-content;
}

.tab-item {
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 9999rpx;
  border: 1rpx solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-text {
  font-size: 24rpx;
  color: var(--cream-3);
}

.tab-item.active {
  border-color: var(--line-strong);
  background: var(--ember-soft);
}

.tab-item.active .tab-text {
  color: var(--cream-0);
}

.feed-wrap {
  position: fixed;
  inset: 0;
  overflow-y: auto;
}

.sec {
  margin-top: 56rpx;
  padding: 0 48rpx;
}

.sec-last {
  padding-bottom: 40rpx;
}

.sec-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.sec-sub-eyebrow {
  display: block;
  font-size: 18rpx;
  margin-bottom: 12rpx;
}

.sec-title-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  flex-wrap: wrap;
}

.sec-title,
.sec-title-it {
  font-size: 44rpx;
}

.sec-count {
  font-size: 18rpx;
}

.waterfall {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.wf-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.work-card {
  border-radius: 24rpx;
  overflow: hidden;
  background: var(--ink-1);
  border: 1rpx solid var(--line);
}

.work-cover {
  position: relative;
  width: 100%;
}

.work-cover.ratio-tall { padding-top: 138%; }
.work-cover.ratio-mid { padding-top: 118%; }
.work-cover.ratio-wide { padding-top: 92%; }

.work-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.work-meta {
  padding: 18rpx;
}

.work-title {
  display: block;
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--cream-1);
  min-height: 64rpx;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.work-sub {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.work-by,
.work-like {
  font-size: 20rpx;
  color: var(--cream-3);
}

.loading-row {
  display: flex;
  justify-content: center;
  padding: 30rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--cream-1);
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--cream-3);
}

@media (max-width: 375px) {
  .sec { padding: 0 24rpx; }
  .waterfall { gap: 12rpx; }
  .wf-col { gap: 12rpx; }
  .work-meta { padding: 14rpx; }
}


/* AI 生成显著标识（合规要求：深度合成-AI绘画类目） */
.ai-banner-inline {
  display: flex; align-items: center; gap: 12rpx;
  margin: 12rpx 24rpx 16rpx;
  padding: 14rpx 18rpx;
  background: rgba(232, 106, 60, 0.10);
  border: 1rpx solid rgba(232, 106, 60, 0.28);
  border-radius: 16rpx;
}
.ai-banner-badge {
  font-family: var(--f-mono);
  font-size: 18rpx; font-weight: 700;
  color: #fff; background: var(--ember);
  padding: 4rpx 10rpx; border-radius: 6rpx;
  letter-spacing: 0.06em;
}
.ai-banner-t { font-size: 22rpx; color: var(--cream-1); letter-spacing: 0.02em; }

.ai-corner {
  position: absolute;
  top: 12rpx; right: 12rpx;
  z-index: 2;
  font-family: var(--f-mono);
  font-size: 18rpx; font-weight: 700;
  color: #fff; background: rgba(0, 0, 0, 0.55);
  padding: 4rpx 10rpx; border-radius: 6rpx;
  letter-spacing: 0.06em;
  backdrop-filter: blur(4rpx);
  -webkit-backdrop-filter: blur(4rpx);
}
.work-cover { position: relative; }

