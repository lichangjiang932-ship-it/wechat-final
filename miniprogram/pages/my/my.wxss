/* My · Profile editorial */
.page { background: var(--ink-0); min-height: 100vh; }
.scroll { height: 100vh; box-sizing: border-box; }

.label, .eyebrow { font-family: var(--f-mono); font-size: 18rpx; letter-spacing: 0.22em; color: var(--cream-3); text-transform: uppercase; }
.display { font-family: var(--f-display); color: var(--cream-0); letter-spacing: -0.01em; }
.display-italic { font-style: italic; font-family: var(--f-display); }

/* Icons */
.ic { background: currentColor; color: var(--cream-2); width: 38rpx; height: 38rpx; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center; -webkit-mask-size: contain; }
.ic-cog { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='3'/><path d='M19.4 15a1.65 1.65 0 0 0 .3 1.8l.1.1a2 2 0 0 1-2.8 2.8l-.1-.1a1.65 1.65 0 0 0-1.8-.3 1.65 1.65 0 0 0-1 1.5V21a2 2 0 0 1-4 0v-.1a1.65 1.65 0 0 0-1.1-1.5 1.65 1.65 0 0 0-1.8.3l-.1.1a2 2 0 0 1-2.8-2.8l.1-.1a1.65 1.65 0 0 0 .3-1.8 1.65 1.65 0 0 0-1.5-1H3a2 2 0 0 1 0-4h.1a1.65 1.65 0 0 0 1.5-1.1 1.65 1.65 0 0 0-.3-1.8l-.1-.1a2 2 0 0 1 2.8-2.8l.1.1a1.65 1.65 0 0 0 1.8.3h.1a1.65 1.65 0 0 0 1-1.5V3a2 2 0 0 1 4 0v.1a1.65 1.65 0 0 0 1 1.5 1.65 1.65 0 0 0 1.8-.3l.1-.1a2 2 0 0 1 2.8 2.8l-.1.1a1.65 1.65 0 0 0-.3 1.8v.1a1.65 1.65 0 0 0 1.5 1H21a2 2 0 0 1 0 4h-.1a1.65 1.65 0 0 0-1.5 1z'/></svg>"); }
.ic-crown { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><path d='M3 7l4 5 5-7 5 7 4-5-2 12H5z'/></svg>"); }
.ic-grid { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='3' width='7' height='7'/><rect x='14' y='3' width='7' height='7'/><rect x='3' y='14' width='7' height='7'/><rect x='14' y='14' width='7' height='7'/></svg>"); }
.ic-bookmark { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z'/></svg>"); }
.ic-download { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3'/></svg>"); }
.ic-globe { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='9'/><path d='M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18'/></svg>"); }
.ic-chev { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 10 14' fill='none' stroke='black' stroke-width='1.4' stroke-linecap='round' stroke-linejoin='round'><path d='m2 2 5 5-5 5'/></svg>"); }
.ic-heart { -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z'/></svg>"); }

/* Header */
.head { display: flex; align-items: center; justify-content: space-between; padding: 40rpx 48rpx 0; }
.head-eyebrow { font-size: 20rpx; color: var(--cream-2); }

/* Avatar row */
.avatar-row { display: flex; align-items: center; gap: 32rpx; padding: 48rpx 48rpx 0; }
.avatar-wrap { position: relative; width: 144rpx; height: 144rpx; border-radius: 50%; overflow: hidden; flex-shrink: 0; }
.avatar-img { width: 100%; height: 100%; }
.avatar-info { flex: 1; display: flex; flex-direction: column; gap: 14rpx; min-width: 0; }
.name-row { display: flex; align-items: baseline; }
.name-text { font-size: 52rpx; line-height: 1; color: var(--cream-0); }
.name-dot { font-size: 52rpx; line-height: 1; color: var(--ember); }
.name-meta { font-size: 18rpx; color: var(--cream-3); letter-spacing: 0.18em; }

/* Stats row */
.stats-row { display: flex; padding: 48rpx 48rpx 0; gap: 4rpx; }
.stat-cell { flex: 1; display: flex; flex-direction: column; align-items: flex-start; gap: 6rpx; min-width: 0; }
.stat-n { font-size: 48rpx; line-height: 1; color: var(--cream-0); }
.stat-l { font-size: 14rpx; color: var(--cream-3); letter-spacing: 0.16em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }

/* VIP membership card */
.vip-card { position: relative; margin: 56rpx 48rpx 0; padding: 44rpx 44rpx 40rpx; border-radius: 40rpx; background: linear-gradient(135deg, #E86A3C 0%, #8A3B1F 100%); overflow: hidden; box-shadow: 0 20rpx 56rpx -16rpx rgba(232,106,60,0.4); }
.vip-ring { position: absolute; border-radius: 50%; pointer-events: none; }
.vip-ring-outer { width: 440rpx; height: 440rpx; right: -120rpx; top: -120rpx; border: 1rpx solid rgba(253,251,245,0.12); }
.vip-ring-inner { width: 320rpx; height: 320rpx; right: -60rpx; top: -60rpx; border: 1rpx solid rgba(253,251,245,0.2); }
.vip-body { position: relative; }
.vip-head { display: flex; align-items: center; gap: 14rpx; }
.vip-crown { width: 36rpx; height: 36rpx; color: var(--cream-0); }
.vip-label { color: var(--cream-0); font-size: 18rpx; letter-spacing: 0.22em; }
.vip-title { display: block; margin-top: 28rpx; font-size: 52rpx; line-height: 1.12; color: var(--cream-0); }
.vip-title + .vip-title { margin-top: 0; }
.vip-foot { display: flex; align-items: flex-end; justify-content: space-between; margin-top: 40rpx; }
.vip-price-row { display: flex; align-items: baseline; gap: 6rpx; }
.vip-price { font-size: 56rpx; line-height: 1; color: var(--cream-0); }
.vip-unit { font-size: 24rpx; color: rgba(253,251,245,0.72); }
.vip-upgrade { padding: 16rpx 28rpx; border-radius: 9999rpx; background: var(--cream-0); color: #B24A1E; font-size: 22rpx; font-weight: 600; letter-spacing: 0.04em; }

/* Menu list */
.menu-list { margin: 48rpx 48rpx 0; }
.menu-row { display: flex; align-items: center; gap: 28rpx; padding: 36rpx 0; border-bottom: 1rpx solid var(--line); }
.menu-ic { width: 36rpx; height: 36rpx; color: var(--cream-2); flex-shrink: 0; }
.menu-text { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.menu-n { font-size: 30rpx; color: var(--cream-0); font-family: var(--f-display); }
.menu-en { font-size: 16rpx; color: var(--cream-3); letter-spacing: 0.16em; text-transform: none; }
.menu-k { font-family: var(--f-mono); font-size: 20rpx; color: var(--cream-3); letter-spacing: 0.08em; }
.menu-chev { width: 20rpx; height: 28rpx; color: var(--cream-4); flex-shrink: 0; }

/* Footer */
.foot { padding: 56rpx 48rpx 0; text-align: center; }
.foot-brand { display: block; font-size: 28rpx; color: var(--cream-3); }
.foot-version { display: block; margin-top: 10rpx; font-size: 16rpx; color: var(--cream-4); letter-spacing: 0.22em; }

.dock-spacer { height: 200rpx; }

/* Popup — sits above custom tab-bar (z=1000) */
.popup-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.68); z-index: 9000; transition: opacity 0.25s ease; backdrop-filter: blur(6rpx); }
.popup-mask.hidden { opacity: 0; pointer-events: none; }
.popup-sheet { position: fixed; left: 0; right: 0; bottom: 0; z-index: 9001; background: var(--ink-1); border-radius: 44rpx 44rpx 0 0; padding: 24rpx 44rpx 56rpx; transform: translateY(100%); transition: transform 0.35s cubic-bezier(0.22,1,0.36,1); padding-bottom: calc(64rpx + env(safe-area-inset-bottom)); box-shadow: 0 -24rpx 80rpx rgba(0,0,0,0.5); }
.popup-sheet.show { transform: translateY(0); }
.popup-handle { width: 72rpx; height: 6rpx; border-radius: 3rpx; background: var(--cream-4); margin: 0 auto 28rpx; opacity: 0.5; }

/* Login sheet */
.login-sheet { padding-top: 16rpx; }
.login-head { padding: 8rpx 12rpx 40rpx; }
.login-eyebrow { display: block; font-size: 18rpx; color: var(--ember); letter-spacing: 0.22em; margin-bottom: 20rpx; }
.login-title { display: block; font-size: 68rpx; line-height: 0.98; color: var(--cream-0); }
.login-title-it { display: block; font-size: 68rpx; line-height: 0.98; color: var(--cream-0); }
.login-sub { display: block; margin-top: 20rpx; font-size: 24rpx; color: var(--cream-3); line-height: 1.55; }

.login-fields { display: flex; flex-direction: column; gap: 28rpx; padding: 0 4rpx; }
.login-field { display: flex; flex-direction: column; gap: 16rpx; }
.login-field-label { font-size: 18rpx; color: var(--cream-3); letter-spacing: 0.2em; }
.login-avatar-btn { width: 100%; padding: 32rpx; margin: 0; background: var(--ink-2); border: 1rpx dashed var(--line-strong); border-radius: 28rpx; display: flex; align-items: center; justify-content: center; gap: 20rpx; min-height: 152rpx; box-sizing: border-box; }
.login-avatar-btn::after { border: none; }
.login-avatar-img { width: 88rpx; height: 88rpx; border-radius: 50%; }
.login-avatar-plus { width: 60rpx; height: 60rpx; border-radius: 50%; border: 1rpx solid var(--line-strong); display: flex; align-items: center; justify-content: center; color: var(--cream-2); font-size: 36rpx; font-weight: 200; line-height: 1; }
.login-avatar-hint { font-size: 26rpx; color: var(--cream-2); font-family: var(--f-display); }
.login-input-box { padding: 28rpx 32rpx; border-radius: 28rpx; background: var(--ink-2); border: 1rpx solid var(--line); }
.login-input { width: 100%; font-family: var(--f-display); font-size: 32rpx; color: var(--cream-0); letter-spacing: -0.01em; }
.login-ph { color: var(--cream-4); font-family: var(--f-display); }

.login-actions { padding-top: 44rpx; display: flex; flex-direction: column; gap: 20rpx; align-items: center; }
.login-policy { font-size: 20rpx; color: var(--cream-4); letter-spacing: 0.05em; text-align: center; }
.login-link { color: var(--cream-2); }

/* Buttons */
.btn-ember { width: 100%; height: 108rpx; border-radius: 9999rpx; background: linear-gradient(145deg, #EE7A50 0%, #D45830 100%); display: flex; align-items: center; justify-content: center; color: #FFF8F0; font-size: 30rpx; letter-spacing: 0.05em; box-shadow: 0 16rpx 40rpx -10rpx rgba(232,106,60,0.55); box-sizing: border-box; }
.btn-ember:active { opacity: 0.92; transform: scale(0.98); }

/* ===== Settings sheet (language + theme) ===== */
.settings-sheet { padding-top: 16rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); }
.settings-head { padding: 8rpx 12rpx 32rpx; }
.settings-eyebrow { display: block; font-size: 18rpx; letter-spacing: 0.22em; color: var(--ember); margin-bottom: 18rpx; }
.settings-title { font-size: 64rpx; line-height: 1; color: var(--cream-0); }
.settings-title-it { font-size: 64rpx; line-height: 1; color: var(--ember); margin-left: 10rpx; }

.settings-group { margin-top: 36rpx; padding: 0 4rpx; }
.settings-group-label { display: block; font-size: 18rpx; color: var(--cream-3); letter-spacing: 0.22em; margin-bottom: 18rpx; }

.settings-seg { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; }
.settings-seg-cell {
  position: relative;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: var(--ink-2);
  border: 1rpx solid var(--line);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  transition: all 0.2s ease;
}
.settings-seg-cell.on {
  background: linear-gradient(145deg, var(--ink-3) 0%, var(--ink-2) 100%);
  border-color: var(--ember);
  box-shadow: 0 0 0 1rpx var(--ember-soft), 0 12rpx 32rpx -12rpx var(--ember-glow);
}
.settings-seg-n { font-family: var(--f-display); font-size: 36rpx; color: var(--cream-0); letter-spacing: -0.01em; }
.settings-seg-cell.on .settings-seg-n { color: var(--ember); }
.settings-seg-en { font-size: 16rpx; color: var(--cream-3); letter-spacing: 0.18em; }

.settings-swatch { width: 44rpx; height: 44rpx; border-radius: 12rpx; margin-bottom: 6rpx; border: 1rpx solid var(--line-strong); }
.swatch-dark { background: linear-gradient(135deg, #0E0B08 0%, #2A2118 100%); }
.swatch-light { background: linear-gradient(135deg, #F6F1EA 0%, #DDD2BE 100%); }

.settings-actions { padding-top: 44rpx; }
